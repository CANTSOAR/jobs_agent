# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Safe to expose to the browser — these are the public anon key + URL, not secrets.
# Find them under Project Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
