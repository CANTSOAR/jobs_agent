# Jobs Agent Environment Variables — copy this file to .env and fill in real values.
# .env is gitignored; never commit your real keys.

# Supabase (used by the Python agent)
SUPABASE_URL="https://your-project.supabase.co"
# Must be the service_role (secret) key, not the anon/publishable key — the agent
# needs to bypass RLS to write companies/jobs/etc. Find it under Project Settings > API.
SUPABASE_KEY="your-service-role-secret-key"

# DeepSeek AI (used by the Python agent for job relevance + company review)
DEEPSEEK_API_KEY="your-deepseek-api-key"

# NTFY for phone notifications
NTFY_TOPIC="your-ntfy-topic"

# SMTP for email notifications
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
